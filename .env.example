APP_ENV=development
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
POSTGRES_DB=aquaops
POSTGRES_USER=aquaops
POSTGRES_PASSWORD=replace-with-a-local-development-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://aquaops:replace-with-a-local-development-password@localhost:5432/aquaops
AUTO_CREATE_TABLES=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_CONNECT_TIMEOUT_SECONDS=5
SESSION_COOKIE_NAME=aquaops_session
SESSION_TTL_DAYS=30
DATA_DIR=./data
MEDIA_ROOT=./media
